{
  "camera": {
    "default_id": 0,
    "resolution": {
      "width": 640,
      "height": 480
    }
  },
  "model": {
    "default_path": "",
    "conf_threshold": 0.5,
    "iou_threshold": 0.45
  },
  "pose_analysis": {
    "enabled": true,
    "default_model": "yolo/yolov8n-pose.pt",
    "conf_threshold": 0.5,
    "keypoint_confidence": 0.5,
    "draw_skeleton": true,
    "draw_keypoints": true,
    "calculate_angles": true
  },
  "training": {
    "epochs": 100,
    "batch_size": 16,
    "learning_rate": 0.001,
    "img_size": 640
  },
  "data": {
    "base_dir": "data",
    "train_ratio": 0.8,
    "val_ratio": 0.1,
    "test_ratio": 0.1
  },
    "defects": [
    "solder_bridge", 
    "missing_solder",
    "insufficient_solder",
    "excess_solder",
    "tombstoning",
    "misalignment"
  ]
}
